# VOXEMPIRE — Umgebungsvariablen für die Produktion.
# Auf dem Server nach /opt/voxempire/.env kopieren und ausfüllen.
# Diese Datei NICHT mit echten Werten committen.

# --- Server ---
PORT=8090
VOX_SPEED=3
VOX_PROTECTION_MIN=1440
# Moderatoren (Chat löschen / Spieler sperren), Komma-getrennte Spielernamen.
# VOX_ADMINS=paddy,gm2

# --- Push-Benachrichtigungen / Apple APNs (optional; siehe CAPACITOR.md) ---
# Alle vier setzen, um den Push-Versand zu aktivieren (sonst No-Op).
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=YYYYYYYYYY
# APNS_BUNDLE_ID=de.kittelberger.voxempire
# APNS_KEY="-----BEGIN PRIVATE KEY-----\n…\n-----END PRIVATE KEY-----"

# --- Datenbank (Upstash Redis, REST-API) ---
# Aus dem Upstash-Dashboard: Database -> REST API
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
VOX_DB_KEY=voxempire:db

# --- Item-Shop / PayPal (optional; leer lassen = Testmodus ohne echte Zahlung) ---
# PAYPAL_ENV=live
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=

# --- E-Mail-Versand (optional; leer lassen = Testmodus: Links werden nur geloggt) ---
# Für Bestätigungs- und Passwort-Reset-Mails. Default-Anbieter: Resend.
# APP_BASE_URL=https://deine-domain.de
# MAIL_PROVIDER=resend
# MAIL_API_KEY=re_xxxxxxxxxxxx
# MAIL_FROM=VOXEMPIRE <no-reply@deine-domain.de>
